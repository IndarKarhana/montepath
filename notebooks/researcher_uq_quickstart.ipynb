        "# Researcher UQ Quickstart\n",
        "\n",
        "Use benchmark helpers to inspect analytic-error UQ rows."
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "from montepath import run_benchmarks\n",
        "\n",
        "results = run_benchmarks(profile=\"compact\", release=False)\n",
        "for row in results:\n",
        "    if \"gaussian_uncertainty\" in row.benchmark_name:\n",
        "        print(row)"
      ]
